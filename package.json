{
  "name": "n8n-nodes-outlook-subscription",
  "version": "0.1.3",
  "description": "n8n community nodes for Microsoft Outlook mail and folder subscriptions via Microsoft Graph",
  "license": "MIT",
  "homepage": "https://github.com/boaz-lai/n8n-nodes-outlook-subscription",
  "repository": {
    "type": "git",
    "url": "https://github.com/boaz-lai/n8n-nodes-outlook-subscription.git"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "microsoft-graph",
    "outlook",
    "subscription",
    "webhook"
  ],
  "author": "Boaz Lai",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch --preserveWatchOutput",
    "dev:docker": "node scripts/watch-and-restart.mjs",
    "docker:restart": "docker compose -f ../n8n/docker-compose.wsl.yml restart n8n",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/OutlookSubscription/OutlookSubscription.node.js",
      "dist/nodes/OutlookSubscriptionNotificationTrigger/OutlookSubscriptionNotificationTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "n8n-workflow": "^1.82.0",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
